MARKETPLACE_API_PORT=4000
JWT_SECRET=change-this-secret-before-production
CLIENT_ORIGIN=*
NODE_ENV=development

# MongoDB Atlas or any MongoDB connection string.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/bazaar_local

# Cloudinary stores uploaded photos online so friends can see them after deploy.
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Optional. Leave unset during local mobile testing so image URLs use the request host.
# PUBLIC_BASE_URL=http://localhost:4000
